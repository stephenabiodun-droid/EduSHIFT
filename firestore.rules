rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) && 
             data.keys().size() == 2 && 
             data.email is string && data.email.size() <= 200 &&
             data.role is string && (data.role == 'user' || data.role == 'admin');
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && 
                       isValidId(userId) && 
                       request.auth.uid == userId && 
                       isValidUser(incoming());
      allow update: if isSignedIn() && 
                       isValidId(userId) && 
                       request.auth.uid == userId && 
                       isValidUser(incoming()) && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['email', 'role']);
      allow delete: if isAdmin();
    }
  }
}
